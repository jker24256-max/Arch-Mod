#!/usr/bin/env bash
# ==============================================================================
# JKER OS SSD, Gaming, and Laptop Power Optimizer
# Configures system parameters, kernel variables, and scheduler profiles.
# ==============================================================================

set -euo pipefail

echo "=== INITIATING JKER OS OPTIMIZATIONS ==="

# 1. SSD / NVMe Optimizations
echo "[OPT] Configuring SSD trim scheduling and block parameters..."
if systemctl list-unit-files | grep -q "fstrim.timer"; then
    systemctl enable fstrim.timer
    echo "[OPT] Enabled weekly fstrim.timer."
fi

# Set optimal disk schedulers for non-rotational drives
for dev in /sys/block/*; do
    if [ -f "$dev/queue/rotational" ]; then
        rot=$(cat "$dev/queue/rotational")
        dev_name=$(basename "$dev")
        if [ "$rot" -eq 0 ]; then
            echo "[OPT] Drive $dev_name is SSD. Setting scheduler to 'none'."
            echo "none" > "$dev/queue/scheduler" || true
        else
            echo "[OPT] Drive $dev_name is HDD. Setting scheduler to 'bfq'."
            echo "bfq" > "$dev/queue/scheduler" || true
        fi
    fi
done

# 2. Kernel Virtual Memory & Swap Optimization
echo "[OPT] Applying memory map and writeback swap optimizations..."
sysctl -w vm.max_map_count=1048576 || true
sysctl -w vm.swappiness=10 || true

# Save persistently
cat <<EOF > /etc/sysctl.d/99-jker-gaming.conf
# JKER OS Kernel Optimizations
vm.max_map_count=1048576
vm.swappiness=10
EOF

# 3. High-Throughput Network Optimizations (BBR)
echo "[OPT] Loading BBR congestion control module..."
modprobe tcp_bbr || true
sysctl -w net.core.default_qdisc=fq || true
sysctl -w net.ipv4.tcp_congestion_control=bbr || true

cat <<EOF > /etc/sysctl.d/99-jker-network.conf
# JKER TCP BBR Congestion Control
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
EOF

# 4. Laptop Battery & Thermal Controls
echo "[OPT] Configuring TLP and CPU power profiles..."
if systemctl list-unit-files | grep -q "tlp.service"; then
    systemctl enable tlp.service
    echo "[OPT] Enabled TLP battery manager service."
fi

if systemctl list-unit-files | grep -q "power-profiles-daemon.service"; then
    systemctl enable power-profiles-daemon.service
    echo "[OPT] Enabled power-profiles-daemon."
fi

echo "=== JKER OS OPTIMIZATIONS COMPLETE ==="
